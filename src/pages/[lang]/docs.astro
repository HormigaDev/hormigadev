---
import Layout from "../../layouts/Layout.astro";
import { useTranslations } from "../../i18n/utils";
import LanguagePicker from "../../components/LanguagePicker.vue";
import "../../styles/global.css";

export function getStaticPaths() {
  return [
    { params: { lang: "es" } },
    { params: { lang: "en" } },
    { params: { lang: "pt" } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang);
---

<Layout title={`${t("section.docs")} — HormigaDev`} lang={lang}>
  <header class="sticky top-0 z-50 border-b border-tech-secondary/10 bg-tech-dark/90 backdrop-blur-sm">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href={`/${lang}/`} class="flex items-center gap-3 group">
        <img 
          src="/assets/avatar.png" 
          alt="HormigaDev" 
          class="w-9 h-9 rounded-full ring-2 ring-discord-blurple/40 group-hover:ring-discord-blurple transition-all" 
        />
        <span 
          class="text-xl font-bold text-discord-blurple font-mono tracking-tight group-hover:text-discord-blurple/80 transition-colors"
        >
          HormigaDev
        </span>
      </a>
      <nav class="flex items-center gap-6">
        <a href={`/${lang}/#engineering`} class="text-sm font-mono text-tech-secondary hover:text-discord-blurple transition-colors">
          {t("nav.projects")}
        </a>
        <a href={`/${lang}/#stack`} class="text-sm font-mono text-tech-secondary hover:text-discord-blurple transition-colors">
          {t("nav.stack")}
        </a>
        <a href={`/${lang}/docs/`} class="text-sm font-mono text-discord-blurple border-b-2 border-discord-blurple">
          {t("nav.docs")}
        </a>
        <LanguagePicker client:load currentLang={lang} />
      </nav>
    </div>
  </header>

  <main class="flex-1">
    <section class="py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-6">
        <div class="mb-8">
          <a 
            href={`/${lang}/`}
            class="inline-flex items-center gap-2 text-sm font-mono text-tech-secondary hover:text-discord-blurple transition-colors mb-6"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            {t("docs.back")}
          </a>
        </div>

        <div class="mb-12">
          <h1 class="text-4xl md:text-5xl font-bold font-mono text-gray-100 mb-4 flex items-center gap-4">
            <span class="text-discord-blurple/40">//</span>
            {t("docs.title")}
          </h1>
          <p class="text-lg text-tech-secondary font-mono">
            {t("docs.subtitle")}
          </p>
        </div>

        <div class="border border-tech-secondary/10 rounded-lg bg-tech-darker p-12">
          <div class="text-center">
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-tech-dark mb-6">
              <svg class="w-10 h-10 text-discord-blurple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h2 class="text-2xl font-mono font-bold text-gray-100 mb-3">
              {t("docs.empty")}
            </h2>
            <p class="text-tech-secondary font-mono text-sm max-w-md mx-auto">
              📚 Miga CLI • 🔧 Patto Ecosystem • 🍷 Vin Rouge
            </p>
          </div>
        </div>

        <div class="mt-16 grid md:grid-cols-3 gap-6">
          <div class="border border-tech-secondary/10 rounded-lg bg-tech-darker p-6 hover:border-discord-blurple/30 transition-all">
            <div class="text-3xl mb-3">🦀</div>
            <h3 class="text-lg font-mono font-bold text-gray-100 mb-2">Miga CLI</h3>
            <p class="text-sm text-tech-secondary font-mono">Rust scaffolding tool</p>
          </div>

          <div class="border border-tech-secondary/10 rounded-lg bg-tech-darker p-6 hover:border-discord-blurple/30 transition-all">
            <div class="text-3xl mb-3">📘</div>
            <h3 class="text-lg font-mono font-bold text-gray-100 mb-2">Patto Ecosystem</h3>
            <p class="text-sm text-tech-secondary font-mono">TypeScript validation</p>
          </div>

          <div class="border border-tech-secondary/10 rounded-lg bg-tech-darker p-6 hover:border-discord-blurple/30 transition-all">
            <div class="text-3xl mb-3">🍷</div>
            <h3 class="text-lg font-mono font-bold text-gray-100 mb-2">Vin Rouge Bistrô</h3>
            <p class="text-sm text-tech-secondary font-mono">Vue restaurant platform</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
