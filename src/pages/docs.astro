---
import Layout from "../layouts/Layout.astro";
import LanguagePicker from "../components/LanguagePicker.vue";
import MobileNav from "../components/MobileNav.vue";
import { ui } from "../i18n/ui";
import "../styles/global.css";
---

<Layout title="Docs — HormigaDev">
  <header class="sticky top-0 z-50 border-b border-tech-secondary/10 bg-tech-dark/90 backdrop-blur-sm">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-3 sm:py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 sm:gap-3 group">
        <img 
          src="/assets/avatar.png" 
          alt="HormigaDev" 
          class="w-8 h-8 sm:w-9 sm:h-9 rounded-full ring-2 ring-discord-blurple/40 group-hover:ring-discord-blurple transition-all" 
        />
        <span 
          class="text-lg sm:text-xl font-bold text-discord-blurple font-mono tracking-tight group-hover:text-discord-blurple/80 transition-colors"
        >
          HormigaDev
        </span>
      </a>
      
      <nav class="hidden lg:flex items-center gap-6">
        <a href="/#engineering" class="text-sm font-mono text-tech-secondary hover:text-discord-blurple transition-colors" data-i18n="nav.projects">
          
        </a>
        <a href="/#stack" class="text-sm font-mono text-tech-secondary hover:text-discord-blurple transition-colors" data-i18n="nav.stack">
          
        </a>
        <a href="/docs/" class="text-sm font-mono text-discord-blurple border-b-2 border-discord-blurple" data-i18n="nav.docs">
          
        </a>
        <LanguagePicker client:load />
      </nav>
      
      <div class="flex items-center gap-3 lg:hidden">
        <LanguagePicker client:load />
        <MobileNav client:load>
          <div slot="language-picker" class="px-4">
          </div>
        </MobileNav>
      </div>
    </div>
  </header>

  <main class="flex-1">
    <section class="py-12 sm:py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="mb-6 sm:mb-8">
          <a 
            href="/"
            class="inline-flex items-center gap-2 text-xs sm:text-sm font-mono text-tech-secondary hover:text-discord-blurple transition-colors mb-4 sm:mb-6"
          >
            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            <span data-i18n="docs.back"></span>
          </a>
        </div>

        <div class="mb-8 sm:mb-12">
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold font-mono text-gray-100 mb-3 sm:mb-4 flex items-center gap-3 sm:gap-4">
            <span class="text-discord-blurple/40">//</span>
            <span data-i18n="docs.title"></span>
          </h1>
          <p class="text-sm sm:text-base md:text-lg text-tech-secondary font-mono" data-i18n="docs.subtitle">
            
          </p>
        </div>

        <div class="border border-tech-secondary/10 rounded-lg bg-tech-darker p-6 sm:p-12">
          <div class="text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 sm:w-20 sm:h-20 rounded-full bg-tech-dark mb-4 sm:mb-6">
              <svg class="w-8 h-8 sm:w-10 sm:h-10 text-discord-blurple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h2 class="text-xl sm:text-2xl font-mono font-bold text-gray-100 mb-2 sm:mb-3" data-i18n="docs.empty">
              
            </h2>
            <p class="text-tech-secondary font-mono text-xs sm:text-sm max-w-md mx-auto">
              📚 Miga CLI • 🔧 Patto Ecosystem • 🍷 Vin Rouge
            </p>
          </div>
        </div>

        <div class="mt-12 sm:mt-16 grid gap-4 sm:gap-6 md:grid-cols-2 lg:grid-cols-3">
          <div class="border border-tech-secondary/10 rounded-lg bg-tech-darker p-4 sm:p-6 hover:border-discord-blurple/30 transition-all">
            <div class="text-2xl sm:text-3xl mb-2 sm:mb-3">🦀</div>
            <h3 class="text-base sm:text-lg font-mono font-bold text-gray-100 mb-1 sm:mb-2">Miga CLI</h3>
            <p class="text-xs sm:text-sm text-tech-secondary font-mono">Rust scaffolding tool</p>
          </div>

          <div class="border border-tech-secondary/10 rounded-lg bg-tech-darker p-4 sm:p-6 hover:border-discord-blurple/30 transition-all">
            <div class="text-2xl sm:text-3xl mb-2 sm:mb-3">📘</div>
            <h3 class="text-base sm:text-lg font-mono font-bold text-gray-100 mb-1 sm:mb-2">Patto Ecosystem</h3>
            <p class="text-xs sm:text-sm text-tech-secondary font-mono">TypeScript validation</p>
          </div>

          <div class="border border-tech-secondary/10 rounded-lg bg-tech-darker p-4 sm:p-6 hover:border-discord-blurple/30 transition-all">
            <div class="text-2xl sm:text-3xl mb-2 sm:mb-3">🍷</div>
            <h3 class="text-base sm:text-lg font-mono font-bold text-gray-100 mb-1 sm:mb-2">Vin Rouge Bistrô</h3>
            <p class="text-xs sm:text-sm text-tech-secondary font-mono">Digital platform</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script is:inline define:vars={{ translations: ui }}>
    let currentLang = localStorage.getItem('preferredLang') || navigator.language.split('-')[0] || 'es';
    
    if (!['es', 'en', 'pt'].includes(currentLang)) {
      currentLang = 'es';
    }
    
    localStorage.setItem('preferredLang', currentLang);
    
    function translate(key, lang = currentLang) {
      return translations[lang]?.[key] || translations['es'][key] || key;
    }
    
    function applyTranslations() {
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        el.textContent = translate(key);
      });
      
      document.title = `${translate('section.docs')} — HormigaDev`;
      document.documentElement.lang = currentLang;
    }
    
    applyTranslations();
    
    window.addEventListener('languagechange', (event) => {
      currentLang = event.detail.lang;
      localStorage.setItem('preferredLang', currentLang);
      applyTranslations();
    });
  </script>
</Layout>
